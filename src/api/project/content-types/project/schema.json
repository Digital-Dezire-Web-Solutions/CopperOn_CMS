{
  "kind": "collectionType",
  "collectionName": "projects",
  "info": {
    "singularName": "project",
    "pluralName": "projects",
    "displayName": "Project"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "name": {
      "type": "string"
    },
    "slug": {
      "type": "uid"
    },
    "region": {
      "type": "enumeration",
      "enum": [
        "USA Projects",
        "MEA Projects",
        "Asia-Pacific Projects"
      ]
    },
    "location": {
      "type": "string"
    },
    "sector": {
      "type": "string"
    },
    "infrastructure": {
      "type": "string"
    },
    "image": {
      "type": "media",
      "multiple": true,
      "allowedTypes": [
        "images",
        "files",
        "videos",
        "audios"
      ]
    }
  }
}
